.venv/
__pycache__/
*.pyc
frontend/node_modules/
frontend/.env
# NOTE: frontend/dist/ IS committed on purpose — the deploy (Render, Python-only
# runtime) serves the prebuilt UI, so no Node is needed on the server.
# After changing frontend code: `cd frontend && npm run build`, then commit dist/.
.env
# Local lab images — kept out of the public repo (bring your own to test)
samples/
# Annotation labels (user's lab photos + JSON) — local training data, not committed
labels/
# ML training artifacts (checkpoints, previews, reports) — code is tracked, outputs aren't
ml/runs/
# Claude Code project settings (machine/workflow-specific, not part of the app)
.claude/
